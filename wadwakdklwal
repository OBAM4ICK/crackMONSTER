MenuGroup:AddToggle('KeybindFrameToggle',{Text='Keybind Frame',Default=true,Callback=function(v)
    Library.KeybindFrame.Visible=v end})

Toggles.WatermarkToggle:OnChanged(function() watermarkEnabled=Toggles.WatermarkToggle.Value; Library:SetWatermarkVisibility(watermarkEnabled) end)
Toggles.KeybindFrameToggle:OnChanged(function() Library.KeybindFrame.Visible=Toggles.KeybindFrameToggle.Value end)

Library.ToggleKeybind=Options.MenuKeybind

local fps, frames, lastTime = 0, 0, tick()
RunService.RenderStepped:Connect(function()
    frames+=1
    local now=tick()
    if now-lastTime>=1 then fps=frames; frames=0; lastTime=now end
end)

task.spawn(function()
    while true do
        if watermarkEnabled then
            local ping=0
            local net=Stats:FindFirstChild("Network")
            if net then
                local sv=net:FindFirstChild("ServerStatsItem")
                if sv then local dp=sv:FindFirstChild("Data Ping"); if dp then ping=math.floor(dp:GetValue()) end end
            end
            Library:SetWatermark(string.format("AV∅X | TridentSuvivalV5 | %s | %dfps | %dms | %s", me.Name, fps, ping, os.date("%H:%M")))
        end
        task.wait(1)
    end
end)

