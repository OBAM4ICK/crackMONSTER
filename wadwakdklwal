RunService.RenderStepped:Connect(function(dt)
    if not AB.enabled then
        AB.locked=nil; fovCircle.Visible=false; AB.predX=0; AB.predY=0; return
    end
    fovCircle.Visible=AB.fovEnabled

    local target,targetScore = nil, math.huge
    local camPos = cam.CFrame.Position
    local tDist,tVel,tPart = 0, Vector3.new(), nil
    local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    if AB.locked and AB.locked.Parent then
        local p = getPart(AB.locked)
        if p then
            tDist=(camPos-p.Position).Magnitude; tVel=getVel(AB.locked)
            local sp,on = cam:WorldToViewportPoint(p.Position)
            if on and (Vector2.new(sp.X,sp.Y)-center).Magnitude < AB.fovSize*1.5 then
                target=sp; tPart=p
            else AB.locked=nil end
        else AB.locked=nil end
    end

    if not AB.locked then
        for _,p in ipairs(AB.players) do
            local part = getPart(p)
            if part then
                if (AB.sleeperCheck and isSleeper_AB(p)) or
                   (AB.aiCheck and not isPlayer_AB(p)) or
                   (AB.teamCheck and IsTeam(p)) then continue end
                local dist = (camPos-part.Position).Magnitude
                if dist<=AB.aimRadius then
                    local sp,on = cam:WorldToViewportPoint(part.Position)
                    if on then
                        local d2c = (Vector2.new(sp.X,sp.Y)-center).Magnitude
                        if d2c<AB.fovSize then
                            local w = d2c*(1+dist/500)
                            if w<targetScore then
                                targetScore=w; target=sp; tDist=dist
                                tVel=getVel(p); tPart=part; AB.locked=p
                            end
                        end
                    end
                end
            end
        end
    end

    if not target then AB.locked=nil; AB.predX=0; AB.predY=0 end

    if target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local dx=(target.X-center.X)/AB.smoothness
        local dy=(target.Y-center.Y)/AB.smoothness
        if AB.prediction and AB.hasWeapon and tPart then
            local vm=tVel.Magnitude
            local upOff = AB.weapon.up>0 and (tDist/12)*AB.weapon.up*AB.predUpBase or 0
            local sox,soy = 0,0
            if vm>0.1 then
                local sm=math.min(vm/2,1)
                local mf=(tDist/20)*AB.weapon.side*0.6*sm
                local pp,ons = cam:WorldToViewportPoint(tPart.Position+tVel.Unit*mf)
                if ons then sox=pp.X-target.X; soy=pp.Y-target.Y end
            end
            local sf=math.min(dt*AB.predSmooth, 0.5)
            AB.predX=AB.predX+(sox-AB.predX)*sf
            AB.predY=AB.predY+((soy-upOff)-AB.predY)*sf
            mousemoverel(dx+AB.predX, dy+AB.predY)
        else
            AB.predX=0; AB.predY=0
            mousemoverel(dx, dy)
        end
    else
        AB.predX=0; AB.predY=0
    end
end)

