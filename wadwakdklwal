local STONE_C = getCachedColor(Color3.fromRGB(72,72,72))
local IRON_C1 = getCachedColor(Color3.fromRGB(199,172,120))
local NITRATE_C = getCachedColor(Color3.fromRGB(248,248,248))

local function detectOre(model)
    if oreCache[model] then return oreCache[model].type, oreCache[model].part end
    local fp = model:FindFirstChildOfClass("MeshPart")
    if not fp then oreCache[model]={type=nil,part=nil}; return nil end
    local parts={fp}
    for _,c in ipairs(model:GetChildren()) do
        if c:IsA("MeshPart") and c~=fp then table.insert(parts,c) end
        if #parts>2 then break end
    end
    local t,p
    if #parts==1 and fp.Color==STONE_C then t,p="Stone",fp
    elseif #parts==2 then
        local c1,c2=parts[1].Color,parts[2].Color
        if (c1==STONE_C and c2==IRON_C1) or (c2==STONE_C and c1==IRON_C1) then t,p="Iron",parts[1]
        elseif (c1==NITRATE_C and c2==STONE_C) or (c2==NITRATE_C and c1==STONE_C) then t,p="Nitrate",parts[1] end
    end
    oreCache[model]={type=t,part=p}; return t,p
end

local function addOre(m,ot,op)
    if oreESP[m] then return end
    local tx=Drawing.new("Text"); tx.Text=ot; tx.Size=oreSet.TextSize; tx.Center=true
    tx.Outline=true; tx.OutlineColor=Color3.new(0,0,0); tx.Color=oreColors[ot]; tx.Visible=false
    oreESP[m]={Text=tx,OreType=ot,Part=op}
end
local function removeOre(m)
    local d=oreESP[m]; if d then if d.Text then d.Text:Remove() end; oreESP[m]=nil end; oreCache[m]=nil
end
local function scanOres()
    if not oreSet.Enabled then return end
    for _,m in ipairs(workspace:GetChildren()) do
        if m:IsA("Model") and not oreESP[m] then
            local ot,op=detectOre(m)
            if ot and oreOn[ot] then addOre(m,ot,op) end
        end
    end
end
