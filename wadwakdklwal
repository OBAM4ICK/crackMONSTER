local function createTrail(proj)
    if projectileTrails[proj] then return end
    if proj.Name=="Arrow" and isLocalArrow(proj) then return end
    local trailData = {points={}}
    trailData.connection = RunService.RenderStepped:Connect(function()
        if not BT.enabled then
            trailData.connection:Disconnect(); projectileTrails[proj]=nil; return
        end
        if not proj or not proj.Parent then
            trailData.connection:Disconnect(); projectileTrails[proj]=nil; return
        end
        if proj.Name=="Arrow" and isLocalArrow(proj) then
            trailData.connection:Disconnect(); projectileTrails[proj]=nil; return
        end
        local pp = proj.Position or proj.CFrame.Position
        table.insert(trailData.points,1,pp)
        if #trailData.points>BT.length then table.remove(trailData.points) end
        for i=1,#trailData.points-1 do
            local p1,p2 = trailData.points[i], trailData.points[i+1]
            local d = (p1-p2).Magnitude
            if d>0.5 then
                local tp = Instance.new("Part")
                tp.Anchored=true; tp.CanCollide=false; tp.CanQuery=false; tp.CanTouch=false
                tp.Size=Vector3.new(BT.thickness,BT.thickness,d)
                tp.CFrame=CFrame.new(p1,p2)*CFrame.new(0,0,-d/2)
                tp.Color=BT.color; tp.Material=Enum.Material.ForceField; tp.Parent=workspace
                Debris:AddItem(tp,BT.lifetime)
            end
        end
    end)
    projectileTrails[proj]=trailData
end

