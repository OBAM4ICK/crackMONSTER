    local cur=root
    for _,p in ipairs(paths) do cur=cur:FindFirstChild(p); if not cur then return nil end end
    return cur
end

local function saveArmProps()
    for _,paths in ipairs(armPaths) do
        local p = findPath_AC(workspace,paths)
        if p and p:IsA("BasePart") and not origArmProps[p] then
            origArmProps[p]={Material=p.Material,Color=p.Color}
        end
    end
end

local function updateArmParts()
    armParts={}
    for _,paths in ipairs(armPaths) do
        local p = findPath_AC(workspace,paths)
        if p and p:IsA("BasePart") then table.insert(armParts,p) end
    end
end

local function applyArmChams()
    if not AC.enabled then
        for part,props in pairs(origArmProps) do
            if part and part.Parent then part.Material=props.Material; part.Color=props.Color end
        end
        return
    end
    for _,p in ipairs(armParts) do
        if p and p.Parent then p.Material=Enum.Material.ForceField; p.Color=AC.color end
    end
end

