local function IsTeam(player)
    if not player then return false end
    local head = player:FindFirstChild("Head")
    if head and head:FindFirstChild("Dot") and head.Dot.Enabled == true then return true end
    return false
end

local function is_sleeping(model)
    if not model then return false end
    if model:GetAttribute("Sleeping") == true or model:GetAttribute("IsSleeping") == true or model:GetAttribute("Asleep") == true or model:GetAttribute("Sleep") == true then return true end
    local lower = model:FindFirstChild("LowerTorso")
    if lower then
        local rootrig = lower:FindFirstChild("RootRig")
        if rootrig and typeof(rootrig.CurrentAngle) == "number" and rootrig.CurrentAngle ~= 0 then return true end
    end
    local function get_sleep_flag(m, name)
        local v = m:FindFirstChild(name, true)
        if v and v.ClassName == "BoolValue" then return v.Value end
        return false
    end
    if get_sleep_flag(model, "Sleeping") or get_sleep_flag(model, "IsSleeping") or get_sleep_flag(model, "Asleep") or get_sleep_flag(model, "Sleep") then return true end
    local rootPart = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("RootPart") or model:FindFirstChild("Torso")
    if rootPart then
        if rootPart.Velocity.Magnitude < 0.1 then
            if rootPart:GetAttribute("Sleeping") == true or rootPart:GetAttribute("IsSleeping") == true then return true end
        end
    end
    local animator = model:FindFirstChild("Animator") or model:FindFirstChildOfClass("Animator")
    if animator and animator:FindFirstChild("Sleep") then return true end
    local parent = model.Parent
    if parent and parent.GetAttribute then
        if parent:GetAttribute("Sleeping") == true or parent:GetAttribute("IsSleeping") == true or parent:GetAttribute("Asleep") == true or parent:GetAttribute("Sleep") == true then return true end
    end
    for _, inst in pairs(model:GetDescendants()) do
        local name = inst.Name and inst.Name:lower() or ""
        if name:find("sleep") then
            if inst.ClassName == "BoolValue" and inst.Value == true then return true end
            if inst.ClassName == "StringValue" and tostring(inst.Value):lower():find("sleep") then return true end
            if inst.GetAttribute then
                if inst:GetAttribute("Sleeping") == true or inst:GetAttribute("IsSleeping") == true or inst:GetAttribute("Asleep") == true or inst:GetAttribute("Sleep") == true then return true end
            end
        end
    end
    return false
end

-- Сохраняем оригинал
local function savePart(part)
    if not originalProperties[part] then
        originalProperties[part] = {
            Size = part.Size,
            Transparency = part.Transparency,
            Color = part.Color,
            Material = part.Material,
            CanCollide = part.CanCollide
        }
    end
end

-- Восстанавливаем оригинал
local function restorePart(part)
    if not part then return end
    local o = originalProperties[part]
    if o then
        part.Size = o.Size
        part.Transparency = o.Transparency
        part.Color = o.Color
        part.Material = o.Material
        part.CanCollide = o.CanCollide
    end
end

-- Применяем хитбокс к части
local function applyHitboxToPart(part)
    if not part or not part:IsA("BasePart") then return end
    savePart(part)
    
    part.Size = Vector3.new(hitboxSizeY, hitboxSizeX, hitboxSizeY)
    part.Transparency = hitboxTransparency
    part.Color = hitboxColor
    
    if canCollideEnabled then
        part.CanCollide = false
    else
        part.CanCollide = originalProperties[part].CanCollide
    end
end

-- Проверка нужно ли пропустить модель
local function shouldSkipModel(model, head, torso)
    if not model then return true end
    if aiCheck and torso and torso.CollisionGroup == "NPC" then return true end
    if sleepCheck and is_sleeping(model) then return true end
    if teamCheck and IsTeam(model) then return true end
    return false
end

-- Останавливаем Mix поток для модели
local function stopMixThread(model)
    if activeMixThreads[model] then
        activeMixThreads[model] = false
        activeMixThreads[model] = nil
    end
end

-- Применяем хитбокс к модели
local function applyHitboxToModel(model)
    local head = model:FindFirstChild("Head")
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
    
    if not head and not torso then return end
    
    stopMixThread(model)
    
    -- Если хитбокс выключен или модель нужно пропустить - восстанавливаем
    if shouldSkipModel(model, head, torso) or not hitboxEnabled then
        if head then restorePart(head) end
        if torso then restorePart(torso) end
        return
    end
    
    -- Обычные режимы
    if hitboxTarget == "Head" then
        if head then 
            applyHitboxToPart(head)
            if torso then restorePart(torso) end
        end
        return
    elseif hitboxTarget == "Torso" then
        if torso then 
            applyHitboxToPart(torso)
            if head then restorePart(head) end
        end
        return
    end
    
    -- MIX режим - исправленная версия с правильными задержками
    if hitboxTarget == "Mix" and (head or torso) then
        activeMixThreads[model] = true
        
        task.spawn(function()
            -- Сначала активируем голову
            if head then 
                applyHitboxToPart(head)
            end
            if torso then 
                restorePart(torso)
            end
            
            -- Цикл переключений
            while activeMixThreads[model] and hitboxEnabled and hitboxTarget == "Mix" do
                -- Проверка перед циклом
                if shouldSkipModel(model, head, torso) then
                    break
                end
                
                -- Ждем mixSpeed секунд (голова активна)
                local start = os.clock()
                while os.clock() - start < mixSpeed and 
                      activeMixThreads[model] and 
                      hitboxEnabled and 
                      hitboxTarget == "Mix" do
                    task.wait()
                    -- Проверяем не нужно ли выйти
                    if shouldSkipModel(model, head, torso) then
                        break
                    end
                end
                
                if not activeMixThreads[model] or not hitboxEnabled or hitboxTarget ~= "Mix" then
                    break
                end
                
                if shouldSkipModel(model, head, torso) then
                    break
                end
                
                -- Переключаем на торс
                if torso then 
                    applyHitboxToPart(torso)
                end
                if head then 
                    restorePart(head)
                end
                
                -- Ждем mixSpeed секунд (торс активен)
                start = os.clock()
                while os.clock() - start < mixSpeed and 
                      activeMixThreads[model] and 
                      hitboxEnabled and 
                      hitboxTarget == "Mix" do
                    task.wait()
                    -- Проверяем не нужно ли выйти
                    if shouldSkipModel(model, head, torso) then
                        break
                    end
                end
                
                if not activeMixThreads[model] or not hitboxEnabled or hitboxTarget ~= "Mix" then
                    break
                end
                
                if shouldSkipModel(model, head, torso) then
                    break
                end
                
                -- Переключаем обратно на голову
                if head then 
                    applyHitboxToPart(head)
                end
                if torso then 
                    restorePart(torso)
                end
            end
            
            -- Восстанавливаем все при выходе
            if head then restorePart(head) end
            if torso then restorePart(torso) end
            activeMixThreads[model] = nil
        end)
    end
end

