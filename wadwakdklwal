local function detectWeapon(model)
    local t = tick()
    local lu = weaponUpdTime[model]
    if lu and t-lu<2 then return weaponCache[model] or "None" end
    local hand = model:FindFirstChild("HandModel")
    if not hand then
        weaponCache[model]="None"; weaponUpdTime[model]=t; return "None"
    end
    local best,bestN = "None", 0
    for wn,parts in pairs(espWeapons) do
        local cnt=0
        for _,p in ipairs(parts) do
            if hand:FindFirstChild(p,true) then cnt=cnt+1 end
        end
        if cnt>bestN then best=wn; bestN=cnt end
    end
    weaponCache[model]=best; weaponUpdTime[model]=t
    return best
end

local function resetWeaponCache(m) weaponCache[m]=nil; weaponUpdTime[m]=nil end

local function updateChams(model, enabled, color)
    if not ES.chams or not enabled then
        if chamsObjects[model] then chamsObjects[model].Enabled=false end; return
    end
    if not chamsObjects[model] or not chamsObjects[model].Parent then
        if chamsObjects[model] then pcall(function() chamsObjects[model]:Destroy() end) end
        local hl = Instance.new("Highlight")
        hl.FillTransparency=0.25; hl.OutlineTransparency=1
        hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
        hl.FillColor=color; hl.Parent=model
        chamsObjects[model]=hl
    else
        chamsObjects[model].FillColor=color; chamsObjects[model].Enabled=true
    end
end

local function hideESP(d)
    d.box.Visible=false; d.nameText.Visible=false; d.weaponText.Visible=false; d.distanceText.Visible=false
end

local function createESP(model)
    if boxes[model] then return end
    local d = {
        box         = Drawing.new("Square"),
        nameText    = Drawing.new("Text"),
        weaponText  = Drawing.new("Text"),
        distanceText= Drawing.new("Text"),
    }
    d.box.Visible=false; d.box.Filled=false; d.box.Thickness=1
    for _,tx in ipairs({d.nameText,d.weaponText,d.distanceText}) do
        tx.Visible=false; tx.Size=11; tx.Center=true; tx.Font=3; tx.Outline=true
    end

    local cachedIsPlayer  = isPlayer_ESP(model)
    local cachedIsSleeper = isSleeper_ESP(model)
    local lastCacheTime   = tick()

    boxes[model]={
        box=d.box, nameText=d.nameText, weaponText=d.weaponText, distanceText=d.distanceText,
        cachedIsPlayer=cachedIsPlayer, cachedIsSleeper=cachedIsSleeper, lastCacheTime=lastCacheTime
    }
end

RunService.RenderStepped:Connect(function(dt)
    local t = tick()
    local camPos = cam.CFrame.Position
    for model, d in pairs(boxes) do
        if not model or not model.Parent then
            hideESP(d); continue
        end
        if not ES.enabled then
            hideESP(d)
            if ES.chams then updateChams(model,false) end
            continue
        end
        local hrp  = model:FindFirstChild("HumanoidRootPart")
        local head = model:FindFirstChild("Head")
        if not hrp or not head then
            hideESP(d)
            if ES.chams then updateChams(model,false) end
            continue
        end
        if t-d.lastCacheTime > 5 then
            d.cachedIsPlayer=isPlayer_ESP(model); d.cachedIsSleeper=isSleeper_ESP(model); d.lastCacheTime=t
        end
        if (ES.teamCheck and IsTeam(model)) or
           (ES.aiCheck and not d.cachedIsPlayer) or
           (ES.sleeperCheck and d.cachedIsSleeper) then
            hideESP(d)
            if ES.chams then updateChams(model,false) end
            continue
        end
        local dist = (camPos-hrp.Position).Magnitude
        if dist>ES.renderDistance then
            hideESP(d)
            if ES.chams then updateChams(model,false) end
            continue
        end
        local pos,vis = cam:WorldToViewportPoint(hrp.Position)
        if not vis then
            hideESP(d)
            if ES.chams then updateChams(model,true,ES.chamsColor) end
            continue
        end
        local scale = 1/(pos.Z*fovTan*2)*100
        local w,h = math.floor(45*scale), math.floor(70*scale)

        d.box.Size=Vector2.new(w,h); d.box.Position=Vector2.new(pos.X-w/2,pos.Y-h/2)
        d.box.Visible=ES.box; d.box.Color=ES.boxColor

        local dtype = d.cachedIsSleeper and "Sleeper" or (d.cachedIsPlayer and "Player" or "Bot")

        if ES.name then
            d.nameText.Text=dtype; d.nameText.Position=Vector2.new(pos.X,pos.Y-h/2-14)
            d.nameText.Visible=true; d.nameText.Color=ES.nameColor
        else d.nameText.Visible=false end

        if ES.weapon then
            d.weaponText.Text=detectWeapon(model); d.weaponText.Position=Vector2.new(pos.X,pos.Y+h/2+2)
            d.weaponText.Visible=true; d.weaponText.Color=ES.weapColor
        else d.weaponText.Visible=false end

        if ES.distance then
            d.distanceText.Text="["..math.floor(dist).."m]"; d.distanceText.Position=Vector2.new(pos.X,pos.Y+h/2+14)
            d.distanceText.Visible=true; d.distanceText.Color=ES.distColor
        else d.distanceText.Visible=false end

        if ES.chams then updateChams(model,true,ES.chamsColor) end
    end
end)

