local sleepCacheAB  = setmetatable({}, {__mode="k"})
local playerCacheAB = setmetatable({}, {__mode="k"})
local lastPosAB     = setmetatable({}, {__mode="k"})

local function isSleeper_AB(m)
    if not m then return false end
    local c = sleepCacheAB[m]
    if c and tick()-c.time < 0.5 then return c.value end
    local lt = m:FindFirstChild("LowerTorso")
    local v = lt and lt:FindFirstChild("RootRig") and
              type(lt.RootRig.CurrentAngle)=="number" and lt.RootRig.CurrentAngle~=0 or false
    sleepCacheAB[m] = {value=v, time=tick()}
    return v
end

local function isPlayer_AB(m)
    local c = playerCacheAB[m]
    if c and tick()-c.time < 1 then return c.value end
    local t = m:FindFirstChild("Torso")
    local v = t and t:FindFirstChild("LeftBooster") and true or false
    playerCacheAB[m] = {value=v, time=tick()}
    return v
end

local function getPath(root, p)
    local cur = root
    for n in p:gmatch("[^/]+") do
        cur = cur:FindFirstChild(n)
        if not cur then return nil end
    end
    return cur
end

local function getWeapon()
    local r = workspace
    for _,n in ipairs({"Const","Ignore","FPSArms"}) do
        r = r:FindFirstChild(n)
        if not r then AB.hasWeapon=false; return nil end
    end
    local hand = r:FindFirstChild("HandModel")
    if not hand then AB.hasWeapon=false; return nil end
    for w,parts in pairs(partSets) do
        local found = 0
        for _,p in ipairs(parts) do
            local part = p:find("/") and getPath(hand,p) or hand:FindFirstChild(p,true)
            if part then found=found+1 end
        end
        if found >= #parts*0.6 then
            AB.hasWeapon=true
            local ws = weaponSets[w]
            if ws then AB.weapon.side=ws.side; AB.weapon.up=ws.up end
            return w
        end
    end
    AB.hasWeapon=false; AB.weapon.side=0; AB.weapon.up=0
    return nil
end

task.spawn(function() while true do task.wait(0.2); getWeapon() end end)

local function getPart(m)
    return m and (m:FindFirstChild("Head") or m:FindFirstChild("UpperTorso") or
                  m:FindFirstChild("LowerTorso") or m:FindFirstChild("HumanoidRootPart"))
end

local function getVel(m)
    if not m then return Vector3.new() end
    local p = getPart(m); if not p then return Vector3.new() end
    local t = tick()
    local last = lastPosAB[m]
    if not last then lastPosAB[m]={pos=p.Position,time=t}; return Vector3.new() end
    local dt = t-last.time; if dt<=0 then return Vector3.new() end
    local vel = (p.Position-last.pos)/dt
    lastPosAB[m]={pos=p.Position,time=t}
    return vel
end

