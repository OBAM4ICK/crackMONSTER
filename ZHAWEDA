        sleepCheck = false,
        aiCheck = false,
        teamCheck = false,
        target = "Head",
        mixSpeed = 1,
        canCollide = false,
    },
    
    Original = {},
    Threads = {},
    Token = 0
}

Hitbox.Save = function(part)
    if not Hitbox.Original[part] then
        Hitbox.Original[part] = {
            Size = part.Size,
            Transparency = part.Transparency,
            Color = part.Color,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

Hitbox.Restore = function(part)
    if not part or not part.Parent then return end
    
    local o = Hitbox.Original[part]
    if not o then return end
    
    part.Size = o.Size
    part.Transparency = o.Transparency
    part.Color = o.Color
    part.Material = o.Material
    part.CanCollide = o.CanCollide
end

Hitbox.ApplyToPart = function(part)
    if not part or not part:IsA("BasePart") then return end
    
    Hitbox.Save(part)
    
    part.Size = Vector3.new(Hitbox.Settings.sizeY, Hitbox.Settings.sizeX, Hitbox.Settings.sizeY)
    part.Transparency = Hitbox.Settings.transparency
    part.Color = Hitbox.Settings.color
    
    if Hitbox.Settings.canCollide then
        part.CanCollide = false
    else
        part.CanCollide = Hitbox.Original[part].CanCollide
    end
end

Hitbox.ShouldSkip = function(model)
    if not model or not model.Parent then return true end
    
    if Hitbox.Settings.aiCheck then
        local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
        if torso and torso.CollisionGroup == "NPC" then return true end
    end
    
    if Hitbox.Settings.sleepCheck then
        local lt = model:FindFirstChild("LowerTorso")
        if lt then
            local rr = lt:FindFirstChild("RootRig")
            if rr and typeof(rr.CurrentAngle) == "number" and rr.CurrentAngle ~= 0 then
                return true
            end
        end
    end
    
    if Hitbox.Settings.teamCheck and Helpers.IsTeam(model) then
        return true
    end
    
    return false
end

Hitbox.Stop = function(model)
    Hitbox.Threads[model] = nil
end

Hitbox.ApplyToModel = function(model, forceRestart)
    local head = model:FindFirstChild("Head")
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
    
    if not head and not torso then return end
    
    if Hitbox.ShouldSkip(model) or not Hitbox.Settings.enabled then
        Hitbox.Stop(model)
        if head then Hitbox.Restore(head) end
        if torso then Hitbox.Restore(torso) end
        return
    end
    
    if Hitbox.Settings.target == "Head" then
        Hitbox.Stop(model)
        if head then Hitbox.ApplyToPart(head) end
        if torso then Hitbox.Restore(torso) end
        
    elseif Hitbox.Settings.target == "Torso" then
        Hitbox.Stop(model)
        if torso then Hitbox.ApplyToPart(torso) end
        if head then Hitbox.Restore(head) end
        
    elseif Hitbox.Settings.target == "Mix" then
        if Hitbox.Threads[model] and not forceRestart then return end
        
        Hitbox.Token = Hitbox.Token + 1
        local myToken = Hitbox.Token
        Hitbox.Threads[model] = myToken
        
        task.spawn(function()
            local phase = 0
            
            while Hitbox.Threads[model] == myToken and Hitbox.Settings.enabled and Hitbox.Settings.target == "Mix" do
                if not model.Parent then break end
                if Hitbox.ShouldSkip(model) then break end
                
                local h = model:FindFirstChild("Head")
                local t = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
                
                if phase == 0 then
                    if h then Hitbox.ApplyToPart(h) end
                    if t then Hitbox.Restore(t) end
                else
                    if t then Hitbox.ApplyToPart(t) end
                    if h then Hitbox.Restore(h) end
                end
                
                phase = 1 - phase
                task.wait(Hitbox.Settings.mixSpeed)
            end
            
            if model.Parent then
                local hh = model:FindFirstChild("Head")
                local tt = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
                if hh then Hitbox.Restore(hh) end
                if tt then Hitbox.Restore(tt) end
            end
        end)
    end
end

Hitbox.IsCandidate = function(m)
    return m:IsA("Model") and m.Name ~= Player.Local.Name and
           (m:FindFirstChild("Head") or m:FindFirstChild("HumanoidRootPart"))
end

Hitbox.UpdateAll = function(forceRestart)
    for _, model in pairs(Services.Workspace:GetChildren()) do
        if Hitbox.IsCandidate(model) then
            Hitbox.ApplyToModel(model, forceRestart)
        end
    end
end

Hitbox.Refresh = function()
    if not Hitbox.Settings.enabled then return end
    if Hitbox.Settings.target == "Mix" then return end
    
    for _, model in pairs(Services.Workspace:GetChildren()) do
        if Hitbox.IsCandidate(model) then
            local part
            
            if Hitbox.Settings.target == "Head" then
                part = model:FindFirstChild("Head")
            else
                part = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
            end
            
            if part then
                Hitbox.ApplyToPart(part)
            end
        end
    end
end

Hitbox.ApplyCanCollide = function()
    for part, o in pairs(Hitbox.Original) do
        if part and part.Parent then
            if Hitbox.Settings.canCollide then
                part.CanCollide = false
            else
                part.CanCollide = o.CanCollide
            end
        end
    end
end

task.spawn(function()
