    RenderInterval = 0.05
}

OreESP.Detect = function(model)
    if OreESP.Cache[model] then
        return OreESP.Cache[model].type, OreESP.Cache[model].part
    end
    
    local fp = model:FindFirstChildOfClass("MeshPart")
    if not fp then
        OreESP.Cache[model] = {type = nil, part = nil}
        return nil
    end
    
    local parts = {fp}
    
    for _, c in ipairs(model:GetChildren()) do
        if c:IsA("MeshPart") and c ~= fp then
            table.insert(parts, c)
        end
        if #parts > 2 then break end
    end
    
    local STONE_C = Color3.fromRGB(72,72,72)
    local IRON_C1 = Color3.fromRGB(199,172,120)
    local NITRATE_C = Color3.fromRGB(248,248,248)
    
    local t, p
    
    if #parts == 1 and fp.Color == STONE_C then
        t, p = "Stone", fp
        
    elseif #parts == 2 then
        local c1, c2 = parts[1].Color, parts[2].Color
        
        if (c1 == STONE_C and c2 == IRON_C1) or (c2 == STONE_C and c1 == IRON_C1) then
            t, p = "Iron", parts[1]
            
        elseif (c1 == NITRATE_C and c2 == STONE_C) or (c2 == NITRATE_C and c1 == STONE_C) then
            t, p = "Nitrate", parts[1]
        end
    end
    
    OreESP.Cache[model] = {type = t, part = p}
    return t, p
end

OreESP.Add = function(m, ot, op)
    if OreESP.ESP[m] then return end
    
    local tx = Drawing.new("Text")
    tx.Text = ot
    tx.Size = OreESP.Settings.textSize
    tx.Center = true
    tx.Outline = true
    tx.OutlineColor = Color3.new(0,0,0)
    tx.Color = OreESP.Types[ot].color
    tx.Visible = false
    
    OreESP.ESP[m] = {
        Text = tx,
        OreType = ot,
        Part = op
    }
end

OreESP.Remove = function(m)
    local d = OreESP.ESP[m]
    if d then
        if d.Text then d.Text:Remove() end
        OreESP.ESP[m] = nil
    end
    OreESP.Cache[m] = nil
end

OreESP.Scan = function()
    if not OreESP.Settings.enabled then return end
    
    for _, m in ipairs(Services.Workspace:GetChildren()) do
        if m:IsA("Model") and not OreESP.ESP[m] then
            local ot, op = OreESP.Detect(m)
            if ot and OreESP.Types[ot].enabled then
                OreESP.Add(m, ot, op)
            end
        end
    end
end

