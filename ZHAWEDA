Services.RunService.RenderStepped:Connect(function()
    ESP.Frame = ESP.Frame + 1
    if ESP.Frame % 2 ~= 0 then return end
    
    local t = tick()
    local camPos = Player.Camera.CFrame.Position
    local espRdSq = ESP.Settings.renderDistance * ESP.Settings.renderDistance
    
    local boxOn = ESP.Settings.box
    local nameOn = ESP.Settings.name
    local distOn = ESP.Settings.distance
    local weapOn = ESP.Settings.weapon
    local chamsOn = ESP.Settings.chams
    local bC, nC, dC, wC, cC = ESP.Settings.boxColor, ESP.Settings.nameColor, ESP.Settings.distColor, ESP.Settings.weapColor, ESP.Settings.chamsColor
    
    for model, d in pairs(ESP.Boxes) do
        if not model or not model.Parent then
            ESP.Hide(d)
            continue
        end
        
        if not ESP.Settings.enabled then
            ESP.Hide(d)
            if chamsOn then ESP.UpdateChams(model, false) end
            continue
        end
        
        local hrp = model:FindFirstChild("HumanoidRootPart")
        local head = model:FindFirstChild("Head")
        
        if not hrp or not head then
            ESP.Hide(d)
            if chamsOn then ESP.UpdateChams(model, false) end
            continue
        end
        
        local diff = hrp.Position - camPos
        local distSq = diff.X*diff.X + diff.Y*diff.Y + diff.Z*diff.Z
        
        if distSq > espRdSq then
            ESP.Hide(d)
            if chamsOn then ESP.UpdateChams(model, false) end
            continue
        end
        
        if t - d.lastCacheTime > 5 then
            d.cachedIsPlayer = ESP.IsPlayer(model)
            d.cachedIsSleeper = ESP.IsSleeper(model)
            d.lastCacheTime = t
        end
        
        if (ESP.Settings.teamCheck and Helpers.IsTeam(model)) or
           (ESP.Settings.aiCheck and not d.cachedIsPlayer) or
           (ESP.Settings.sleeperCheck and d.cachedIsSleeper) then
            ESP.Hide(d)
            if chamsOn then ESP.UpdateChams(model, false) end
            continue
        end
        
        local pos, vis = Player.Camera:WorldToViewportPoint(hrp.Position)
        
        if not vis then
            ESP.Hide(d)
            if chamsOn then ESP.UpdateChams(model, true, cC) end
            continue
        end
        
        local scale = 1 / (pos.Z * ESP.FOVTan * 2) * 100
        local w = math.floor(45 * scale)
        local h = math.floor(70 * scale)
        local px, py = pos.X, pos.Y
        
        if boxOn then
            d.box.Size = Vector2.new(w, h)
            d.box.Position = Vector2.new(px - w/2, py - h/2)
            d.box.Color = bC
            d.box.Visible = true
        else
            d.box.Visible = false
        end
        
        local dtype = d.cachedIsSleeper and "Sleeper" or (d.cachedIsPlayer and "Player" or "Bot")
        
        if nameOn then
            d.nameText.Text = dtype
            d.nameText.Position = Vector2.new(px, py - h/2 - 14)
            d.nameText.Color = nC
            d.nameText.Visible = true
        else
            d.nameText.Visible = false
        end
        
        if weapOn then
            d.weaponText.Text = ESP.DetectWeapon(model)
            d.weaponText.Position = Vector2.new(px, py + h/2 + 2)
            d.weaponText.Color = wC
            d.weaponText.Visible = true
        else
            d.weaponText.Visible = false
        end
        
        if distOn then
            local dist = math.sqrt(distSq)
            d.distanceText.Text = "[" .. math.floor(dist) .. "m]"
            d.distanceText.Position = Vector2.new(px, py + h/2 + 14)
            d.distanceText.Color = dC
            d.distanceText.Visible = true
        else
            d.distanceText.Visible = false
        end
        
        if chamsOn then
            ESP.UpdateChams(model, true, cC)
        end
    end
end)

