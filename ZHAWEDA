Services.RunService.RenderStepped:Connect(function(dt)
    ItemCorpseESP.UpdateTimer = ItemCorpseESP.UpdateTimer + dt
    if ItemCorpseESP.UpdateTimer < ItemCorpseESP.RenderInterval then return end
    ItemCorpseESP.UpdateTimer = 0
    
    local cp = Player.Camera.CFrame.Position
    
    if ItemCorpseESP.Items.Settings.enabled then
        for m, d in pairs(ItemCorpseESP.Items.ESP) do
            local p = d.Part
            
            if p and p.Parent and ItemCorpseESP.Items.Settings.enabledType then
                local dist = (cp - p.Position).Magnitude
                
                if dist <= ItemCorpseESP.Items.Settings.maxDistance then
                    local sp, on = Player.Camera:WorldToViewportPoint(p.Position)
                    
                    if on then
                        if ItemCorpseESP.Items.Settings.show then
                            d.Text.Text = string.format("Item | %.0fm", dist)
                        else
                            d.Text.Text = "Item"
                        end
                        
                        d.Text.Position = Vector2.new(sp.X, sp.Y - 20)
                        d.Text.Visible = true
                    else
                        d.Text.Visible = false
                    end
                else
                    d.Text.Visible = false
                end
            else
                ItemCorpseESP.Items.Remove(m)
            end
        end
    else
        for _, d in pairs(ItemCorpseESP.Items.ESP) do
            if d.Text then d.Text.Visible = false end
        end
    end
    
    if ItemCorpseESP.Corpses.Settings.enabled then
        for m, d in pairs(ItemCorpseESP.Corpses.ESP) do
            local p = d.Part
            
            if p and p.Parent and ItemCorpseESP.Corpses.Settings.enabledType then
                local dist = (cp - p.Position).Magnitude
                
                if dist <= ItemCorpseESP.Corpses.Settings.maxDistance then
                    local sp, on = Player.Camera:WorldToViewportPoint(p.Position)
                    
                    if on then
                        if ItemCorpseESP.Corpses.Settings.show then
                            d.Text.Text = string.format("Corpse | %.0fm", dist)
                        else
                            d.Text.Text = "Corpse"
                        end
                        
                        d.Text.Position = Vector2.new(sp.X, sp.Y - 20)
                        d.Text.Visible = true
                    else
                        d.Text.Visible = false
                    end
                else
                    d.Text.Visible = false
                end
            else
                ItemCorpseESP.Corpses.Remove(m)
            end
        end
    else
        for _, d in pairs(ItemCorpseESP.Corpses.ESP) do
            if d.Text then d.Text.Visible = false end
        end
    end
end)

