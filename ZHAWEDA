Services.RunService.RenderStepped:Connect(function(dt)
    if not CameraSettings.Freecam.enabled then return end
    
    local move = Vector3.zero
    
    if Services.UserInputService:IsKeyDown(Enum.KeyCode.Up) then
        move = move + Player.Camera.CFrame.LookVector
    end
    if Services.UserInputService:IsKeyDown(Enum.KeyCode.Down) then
        move = move - Player.Camera.CFrame.LookVector
    end
    if Services.UserInputService:IsKeyDown(Enum.KeyCode.Left) then
        move = move - Player.Camera.CFrame.RightVector
    end
    if Services.UserInputService:IsKeyDown(Enum.KeyCode.Right) then
        move = move + Player.Camera.CFrame.RightVector
    end
    
    if move.Magnitude > 0 then
        CameraSettings.Freecam.pos = CameraSettings.Freecam.pos + move.Unit * CameraSettings.Freecam.speed * dt
    end
    
    Player.Camera.CFrame = CFrame.new(CameraSettings.Freecam.pos, CameraSettings.Freecam.pos + Player.Camera.CFrame.LookVector)
end)

