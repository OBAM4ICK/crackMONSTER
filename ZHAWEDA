BulletTrails.IsLocalArrow = function(obj)
    local ok, res = pcall(function()
        local fps = Services.Workspace:FindFirstChild("Const") and
                    Services.Workspace.Const:FindFirstChild("Ignore") and
                    Services.Workspace.Const.Ignore:FindFirstChild("FPSArms")
        
        if fps then
            local hm = fps:FindFirstChild("HandModel")
            return hm and hm:FindFirstChild("Arrow") == obj
        end
        
        return false
    end)
    
    return ok and res
end

BulletTrails.Create = function(proj)
    if BulletTrails.Projectiles[proj] then return end
    if proj.Name == "Arrow" and BulletTrails.IsLocalArrow(proj) then return end
    
    local data = {points = {}}
    
    data.connection = Services.RunService.RenderStepped:Connect(function()
        if not BulletTrails.Settings.enabled then
            data.connection:Disconnect()
            BulletTrails.Projectiles[proj] = nil
            return
        end
        
        if not proj or not proj.Parent then
            data.connection:Disconnect()
            BulletTrails.Projectiles[proj] = nil
            return
        end
        
        if proj.Name == "Arrow" and BulletTrails.IsLocalArrow(proj) then
            data.connection:Disconnect()
            BulletTrails.Projectiles[proj] = nil
            return
        end
        
        local pp = proj.Position or proj.CFrame.Position
        table.insert(data.points, 1, pp)
        
        if #data.points > BulletTrails.Settings.length then
            table.remove(data.points)
        end
        
        for i = 1, #data.points - 1 do
            local p1, p2 = data.points[i], data.points[i+1]
            local d = (p1 - p2).Magnitude
            
            if d > 0.5 then
                local tp = Instance.new("Part")
                tp.Anchored = true
                tp.CanCollide = false
                tp.CanQuery = false
                tp.CanTouch = false
                tp.Size = Vector3.new(BulletTrails.Settings.thickness, BulletTrails.Settings.thickness, d)
                tp.CFrame = CFrame.new(p1, p2) * CFrame.new(0, 0, -d/2)
                tp.Color = BulletTrails.Settings.color
                tp.Material = Enum.Material.ForceField
                tp.Parent = Services.Workspace
                
                Services.Debris:AddItem(tp, BulletTrails.Settings.lifetime)
            end
        end
    end)
    
    BulletTrails.Projectiles[proj] = data
end

Services.Workspace.DescendantAdded:Connect(function(obj)
    if obj:IsDescendantOf(Services.ReplicatedStorage) then return end
    
    task.wait()
    
    if not BulletTrails.Settings.enabled then return end
    
    for _, n in ipairs(BulletTrails.BulletNames) do
        if obj.Name == n then
            BulletTrails.Create(obj)
            return
        end
    end
    
    if obj.Name == "Arrow" and not BulletTrails.IsLocalArrow(obj) then
        BulletTrails.Create(obj)
    end
end)

