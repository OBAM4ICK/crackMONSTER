ESP.DetectWeapon = function(model)
    local t = tick()
    local lu = ESP.WeaponTime[model]
    
    if lu and t - lu < 3 then
        return ESP.WeaponCache[model] or "None"
    end
    
    local hand = model:FindFirstChild("HandModel")
    if not hand then
        ESP.WeaponCache[model] = "None"
        ESP.WeaponTime[model] = t
        return "None"
    end
    
    local childSet = {}
    for _, c in ipairs(hand:GetChildren()) do
        childSet[c.Name] = true
    end
    
    local best = "None"
    local bestN = 0
    
    for wn, keys in pairs(ESP.WeaponKeys) do
        local cnt = 0
        for _, k in ipairs(keys) do
            if childSet[k] then
                cnt = cnt + 1
            end
        end
        
        if cnt > bestN then
            best = wn
            bestN = cnt
        end
    end
    
    ESP.WeaponCache[model] = best
    ESP.WeaponTime[model] = t
    
    return best
end

ESP.ResetWeapon = function(m)
    ESP.WeaponCache[m] = nil
    ESP.WeaponTime[m] = nil
end

ESP.UpdateChams = function(model, enabled, color)
    if not ESP.Settings.chams or not enabled then
        if ESP.Chams[model] then
            ESP.Chams[model].Enabled = false
        end
        return
    end
    
    if not ESP.Chams[model] or not ESP.Chams[model].Parent then
        if ESP.Chams[model] then
            pcall(function() ESP.Chams[model]:Destroy() end)
        end
        
        local hl = Instance.new("Highlight")
        hl.FillTransparency = 0.25
        hl.OutlineTransparency = 1
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.FillColor = color
        hl.Parent = model
        
        ESP.Chams[model] = hl
    else
        ESP.Chams[model].FillColor = color
        ESP.Chams[model].Enabled = true
    end
end

