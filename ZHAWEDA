Services.RunService.RenderStepped:Connect(function(dt)
    if not Aimbot.Settings.enabled then
        Aimbot.Settings.locked = nil
        Aimbot.FOV.Visible = false
        Aimbot.Settings.predX = 0
        Aimbot.Settings.predY = 0
        return
    end
    
    Aimbot.FOV.Visible = Aimbot.Settings.fovEnabled
    
    local target = nil
    local targetScore = math.huge
    local camPos = Player.Camera.CFrame.Position
    local tDist = 0
    local tVel = Vector3.new()
    local tPart = nil
    local center = Vector2.new(Player.Camera.ViewportSize.X/2, Player.Camera.ViewportSize.Y/2)
    
    if Aimbot.Settings.locked and Aimbot.Settings.locked.Parent then
        local p = Aimbot.GetPart(Aimbot.Settings.locked)
        if p then
            tDist = (camPos - p.Position).Magnitude
            tVel = Aimbot.GetVel(Aimbot.Settings.locked)
            local sp, on = Player.Camera:WorldToViewportPoint(p.Position)
            
            if on then
                local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if d < Aimbot.Settings.fovSize * 1.5 then
                    target = sp
                    tPart = p
                else
                    Aimbot.Settings.locked = nil
                end
            else
                Aimbot.Settings.locked = nil
            end
        else
            Aimbot.Settings.locked = nil
        end
    end
    
    if not Aimbot.Settings.locked then
        for _, p in ipairs(Aimbot.Settings.players) do
            local part = Aimbot.GetPart(p)
            if part then
                if (Aimbot.Settings.sleeperCheck and Aimbot.IsSleeper(p)) or
                   (Aimbot.Settings.aiCheck and not Aimbot.IsPlayer(p)) or
                   (Aimbot.Settings.teamCheck and Helpers.IsTeam(p)) then
                    continue
                end
                
                local dist = (camPos - part.Position).Magnitude
                if dist <= Aimbot.Settings.aimRadius then
                    local sp, on = Player.Camera:WorldToViewportPoint(part.Position)
                    if on then
                        local d2c = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                        if d2c < Aimbot.Settings.fovSize then
                            local w = d2c * (1 + dist / 500)
                            if w < targetScore then
                                targetScore = w
                                target = sp
                                tDist = dist
                                tVel = Aimbot.GetVel(p)
                                tPart = part
                                Aimbot.Settings.locked = p
                            end
                        end
                    end
                end
            end
        end
    end
    
    if not target then
        Aimbot.Settings.locked = nil
        Aimbot.Settings.predX = 0
        Aimbot.Settings.predY = 0
    end
    
    if target and Services.UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local dx = (target.X - center.X) / Aimbot.Settings.smoothness
        local dy = (target.Y - center.Y) / Aimbot.Settings.smoothness
        
        if Aimbot.Settings.prediction and Aimbot.Settings.hasWeapon and tPart then
            local vm = tVel.Magnitude
            local upOff = Aimbot.Settings.weapon.up > 0 and (tDist / 12) * Aimbot.Settings.weapon.up * Aimbot.Settings.predUpBase or 0
            local sox, soy = 0, 0
            
            if vm > 0.1 then
                local sm = math.min(vm / 2, 1)
                local mf = (tDist / 20) * Aimbot.Settings.weapon.side * 0.6 * sm
                local pp, ons = Player.Camera:WorldToViewportPoint(tPart.Position + tVel.Unit * mf)
                if ons then
                    sox = pp.X - target.X
                    soy = pp.Y - target.Y
                end
            end
            
            local sf = math.min(dt * Aimbot.Settings.predSmooth, 0.5)
            Aimbot.Settings.predX = Aimbot.Settings.predX + (sox - Aimbot.Settings.predX) * sf
            Aimbot.Settings.predY = Aimbot.Settings.predY + ((soy - upOff) - Aimbot.Settings.predY) * sf
            
            mousemoverel(dx + Aimbot.Settings.predX, dy + Aimbot.Settings.predY)
        else
            Aimbot.Settings.predX = 0
            Aimbot.Settings.predY = 0
            mousemoverel(dx, dy)
        end
    else
        Aimbot.Settings.predX = 0
        Aimbot.Settings.predY = 0
    end
end)

