Aimbot.IsSleeper = function(m)
    if not m then return false end
    local c = Aimbot.Cache.sleep[m]
    if c and tick() - c.time < 0.5 then return c.value end
    
    local lt = m:FindFirstChild("LowerTorso")
    local v = false
    
    if lt then
        local rr = lt:FindFirstChild("RootRig")
        if rr and type(rr.CurrentAngle) == "number" and rr.CurrentAngle ~= 0 then
            v = true
        end
    end
    
    Aimbot.Cache.sleep[m] = {value = v, time = tick()}
    return v
end

Aimbot.IsPlayer = function(m)
    local c = Aimbot.Cache.player[m]
    if c and tick() - c.time < 1 then return c.value end
    
    local t = m:FindFirstChild("Torso")
    local v = t and t:FindFirstChild("LeftBooster") and true or false
    
    Aimbot.Cache.player[m] = {value = v, time = tick()}
    return v
end

Aimbot.GetPath = function(root, p)
    local cur = root
    for n in p:gmatch("[^/]+") do
        cur = cur:FindFirstChild(n)
        if not cur then return nil end
    end
    return cur
end

Aimbot.GetWeapon = function()
    local r = Services.Workspace
    
    for _, n in ipairs({"Const", "Ignore", "FPSArms"}) do
        r = r:FindFirstChild(n)
        if not r then
            Aimbot.Settings.hasWeapon = false
            return nil
        end
    end
    
    local hand = r:FindFirstChild("HandModel")
    if not hand then
        Aimbot.Settings.hasWeapon = false
        return nil
    end
    
    for w, parts in pairs(Aimbot.PartSets) do
        local found = 0
        
        for _, p in ipairs(parts) do
            local part
            if p:find("/") then
                part = Aimbot.GetPath(hand, p)
            else
                part = hand:FindFirstChild(p, true)
            end
            
            if part then
                found = found + 1
            end
        end
        
        if found >= #parts * 0.6 then
            Aimbot.Settings.hasWeapon = true
            local ws = Aimbot.WeaponSets[w]
            if ws then
                Aimbot.Settings.weapon.side = ws.side
                Aimbot.Settings.weapon.up = ws.up
            end
            return w
        end
    end
    
    Aimbot.Settings.hasWeapon = false
    Aimbot.Settings.weapon.side = 0
    Aimbot.Settings.weapon.up = 0
    return nil
end

