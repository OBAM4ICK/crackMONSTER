ItemCorpseESP.Items.IsItem = function(m)
    if ItemCorpseESP.Items.Cache[m] ~= nil then
        return ItemCorpseESP.Items.Cache[m]
    end
    
    local v = m:FindFirstChild("Union") and m:FindFirstChild("Display") and m:FindFirstChild("Part")
    ItemCorpseESP.Items.Cache[m] = v
    return v
end

ItemCorpseESP.Items.Add = function(m)
    if ItemCorpseESP.Items.ESP[m] then return end
    
    local tx = Drawing.new("Text")
    tx.Text = "Item"
    tx.Size = ItemCorpseESP.Items.Settings.textSize
    tx.Center = true
    tx.Outline = true
    tx.OutlineColor = Color3.new(0,0,0)
    tx.Color = ItemCorpseESP.Items.Settings.color
    tx.Visible = false
    
    ItemCorpseESP.Items.ESP[m] = {
        Text = tx,
        Part = m:FindFirstChild("Union") or m:FindFirstChild("Display") or m:FindFirstChild("Part")
    }
end

ItemCorpseESP.Items.Remove = function(m)
    local d = ItemCorpseESP.Items.ESP[m]
    if d then
        if d.Text then d.Text:Remove() end
        ItemCorpseESP.Items.ESP[m] = nil
    end
    ItemCorpseESP.Items.Cache[m] = nil
end

ItemCorpseESP.Items.Scan = function()
    if not ItemCorpseESP.Items.Settings.enabled then return end
    
    for _, m in ipairs(Services.Workspace:GetChildren()) do
        if m:IsA("Model") and not ItemCorpseESP.Items.ESP[m] and ItemCorpseESP.Items.Settings.enabledType and ItemCorpseESP.Items.IsItem(m) then
            ItemCorpseESP.Items.Add(m)
        end
    end
end

ItemCorpseESP.Corpses.IsCorpse = function(m)
    if ItemCorpseESP.Corpses.Cache[m] ~= nil then
        return ItemCorpseESP.Corpses.Cache[m]
    end
    
    local parts = {}
    
    for _, c in ipairs(m:GetChildren()) do
        if c:IsA("BasePart") then
            table.insert(parts, c)
        end
        if #parts > 2 then break end
    end
    
    if #parts ~= 2 then
        ItemCorpseESP.Corpses.Cache[m] = false
        return false
    end
    
    local v = (parts[1].Material == Enum.Material.Fabric and parts[2].Material == Enum.Material.Metal) or
              (parts[1].Material == Enum.Material.Metal and parts[2].Material == Enum.Material.Fabric)
    
    ItemCorpseESP.Corpses.Cache[m] = v
    return v
end

ItemCorpseESP.Corpses.Add = function(m)
    if ItemCorpseESP.Corpses.ESP[m] then return end
    
    local tx = Drawing.new("Text")
    tx.Text = "Corpse"
    tx.Size = ItemCorpseESP.Corpses.Settings.textSize
    tx.Center = true
    tx.Outline = true
    tx.OutlineColor = Color3.new(0,0,0)
    tx.Color = ItemCorpseESP.Corpses.Settings.color
    tx.Visible = false
    
    ItemCorpseESP.Corpses.ESP[m] = {
        Text = tx,
        Part = m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
    }
end

ItemCorpseESP.Corpses.Remove = function(m)
    local d = ItemCorpseESP.Corpses.ESP[m]
    if d then
        if d.Text then d.Text:Remove() end
        ItemCorpseESP.Corpses.ESP[m] = nil
    end
    ItemCorpseESP.Corpses.Cache[m] = nil
end

ItemCorpseESP.Corpses.Scan = function()
    if not ItemCorpseESP.Corpses.Settings.enabled then return end
    
    for _, m in ipairs(Services.Workspace:GetChildren()) do
        if m:IsA("Model") and not ItemCorpseESP.Corpses.ESP[m] and ItemCorpseESP.Corpses.Settings.enabledType and ItemCorpseESP.Corpses.IsCorpse(m) then
            ItemCorpseESP.Corpses.Add(m)
        end
    end
end

